{
  "expo": {
    "name": "PTE Flow",
    "slug": "pte-flow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "pte-flow",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
