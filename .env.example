# --- SERVER SIDE KEYS (Used by the Express backend) ---
# Required for OpenAI (ChatGPT 4) Writing Analysis
OPENAI_API_KEY=

# --- CLIENT SIDE KEYS (Used by the Expo App) ---
# Required for Gemini Fallback Analysis (Must start with EXPO_PUBLIC_)
EXPO_PUBLIC_GEMINI_API_KEY=
GEMINI_API_KEY=

# The URL of your backend server. 
# In Expo Go, set this to your computer's IP (e.g., http://192.168.1.5:3000)
# If left blank, the app defaults to the AIS Cloud URL.
EXPO_PUBLIC_API_URL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=
