rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSprint(data) {
      return data.hostId == request.auth.uid &&
             data.hostName is string && data.hostName.size() <= 100 &&
             data.status in ['waiting', 'active', 'finished'] &&
             data.ssid is string && data.ssid.size() <= 100;
    }

    function isValidResult(data) {
      return data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.score is number && data.score >= 0 && data.score <= 1000 &&
             data.timeTaken is number && data.timeTaken >= 0 && data.timeTaken <= 3000;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'projectgazzy@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    // Leaderboard
    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn(); 
    }

    // Config (Global Reset)
    match /config/reset {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Sprints
    match /sprints/{sprintId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSprint(incoming());
      allow update: if isSignedIn() && (
        existing().hostId == request.auth.uid && 
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'startTime', 'duration', 'currentRound', 'participantCount'])
      );
      allow delete: if isSignedIn() && (existing().hostId == request.auth.uid || request.auth.token.email == 'projectgazzy@gmail.com');
      
      match /results/{userId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidResult(incoming());
        allow update: if isSignedIn() && isOwner(userId) && isValidResult(incoming());
      }
    }
  }
}
