{
  "name": "pte-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist-server/server.js",
    "build": "npx expo export -p web --output-dir dist && esbuild server.ts --bundle --platform=node --target=node18 --format=esm --packages=external --define:process.env.NODE_ENV='\"production\"' --outfile=dist-server/server.js",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@google/genai": "^1.29.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-preset-expo": "~12.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "expo": "~52.0.0",
    "expo-av": "~15.0.0",
    "expo-build-properties": "~0.13.3",
    "expo-camera": "~16.0.18",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-linking": "~7.0.0",
    "expo-location": "~18.0.10",
    "expo-network": "~7.0.5",
    "expo-router": "~4.0.0",
    "expo-speech": "~13.0.0",
    "expo-status-bar": "~2.0.0",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-is-edge-to-edge": "^1.3.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
